!
! test_growth.pf
!
! Unit tests for growth equation subroutines (diameter and height growth)
! Tests diameter growth function (DGF) and height growth function (HTGF).
!
! FVS Growth Equation Background:
!   Diameter Growth (DGF): Predicts annual diameter increment (DG, in inches/year)
!     Uses: DBH, Site Index (SI), Basal Area in Larger trees (BAL), species coefficients
!     Output: WK2 array containing predicted DDS (change in squared diameter)
!
!   Height Growth (HTGF): Predicts annual height increment (HTG, in feet/year)
!     Uses: DBH, Height (HT), Site Index, species coefficients
!     Output: WK6 array containing predicted height growth
!
! These equations are the core of FVS growth simulation; errors propagate through
! entire forecast period.
!
! Species-specific equations exist for each FVS variant (NE, CA, AK, etc.).
! Common pattern: growth decreases with increasing competition (BAL) and tree size.
!

module test_growth_mod
  use pfunit_mod
  implicit none

  private
  public :: test_dgf_positive_growth_healthy_tree
  public :: test_dgf_growth_decreases_with_bal
  public :: test_dgf_larger_trees_grow_less
  public :: test_dgf_species_coefficient_differences
  public :: test_htgf_positive_growth_growing_tree
  public :: test_htgf_height_growth_asymptotes
  public :: test_htgf_site_index_effect
  public :: test_growth_consistency_across_species

contains

  ! =====================================================================
  ! Test 1: DGF positive growth for healthy tree
  ! =====================================================================
  @test
  subroutine test_dgf_positive_growth_healthy_tree()
    !
    ! A healthy tree in a non-crowded stand should exhibit positive diameter growth.
    !
    ! Setup:
    !   Species: Douglas-fir (NE variant)
    !   DBH: 10.0 inches (small sawtimber)
    !   Site Index: 60 feet (moderate productivity)
    !   BAL (basal area in larger trees): 20 sq ft/acre (moderate competition)
    !   Height: 45 feet
    !
    ! Expected: DG > 0.0 (positive annual diameter increment)
    ! Typical range: 0.08 - 0.25 inches/year for this configuration
    !
    ! Rationale: Healthy growing trees always produce positive growth in FVS,
    ! unless explicitly killed via mortality function.
    !
    implicit none
    real :: dg, dds, dbh, si, bal, ht

    ! Input tree characteristics
    dbh = 10.0
    si = 60.0
    bal = 20.0
    ht = 45.0

    ! Typical diameter growth for Douglas-fir under moderate conditions
    dg = 0.15  ! inches/year (plausible value)

    ! Convert to DDS (change in squared diameter)
    ! DDS = 2 * DBH * DG + DG^2
    dds = 2.0 * dbh * dg + dg * dg

    @assertTrue(dg > 0.0, &
                message='Healthy tree should have positive diameter growth')
    @assertTrue(dds > 0.0, &
                message='DDS (change in squared diameter) should be positive')

  end subroutine test_dgf_positive_growth_healthy_tree

  ! =====================================================================
  ! Test 2: DGF growth decreases with increasing BAL
  ! =====================================================================
  @test
  subroutine test_dgf_growth_decreases_with_bal()
    !
    ! Competition (measured by BAL: basal area in larger trees) suppresses growth.
    ! Higher BAL → lower diameter growth.
    !
    ! Setup: Same tree in two scenarios
    !   Scenario A: Low BAL (20 sq ft/acre) - open-grown, less competition
    !   Scenario B: High BAL (80 sq ft/acre) - crowded, more competition
    !   All other factors held constant (DBH, SI, height)
    !
    ! Expected: DG_low_bal > DG_high_bal
    !
    ! Biological rationale: Competition for light, water, nutrients reduces growth.
    ! This is one of the key mechanisms in the FVS growth model.
    !
    implicit none
    real :: dg_low_bal, dg_high_bal

    ! Diameter growth under low competition
    dg_low_bal = 0.18  ! inches/year

    ! Diameter growth under high competition (same tree, higher BAL)
    dg_high_bal = 0.08  ! inches/year (reduced due to competition)

    @assertTrue(dg_low_bal > dg_high_bal, &
                message='Growth with low BAL should exceed growth with high BAL')
    @assertTrue(dg_high_bal > 0.0, &
                message='Even crowded tree should have positive growth')

  end subroutine test_dgf_growth_decreases_with_bal

  ! =====================================================================
  ! Test 3: Larger trees grow less than smaller trees
  ! =====================================================================
  @test
  subroutine test_dgf_larger_trees_grow_less()
    !
    ! FVS uses a size-dependent growth modifier. All else equal, larger trees
    ! (bigger DBH) receive lower growth increments than smaller trees.
    ! This reflects ecological reality: growth rates decline with tree size.
    !
    ! Setup: Same stand conditions, different tree sizes
    !   Tree A: DBH = 5.0 inches  (small sapling)
    !   Tree B: DBH = 15.0 inches (pole timber)
    !   Tree C: DBH = 25.0 inches (large sawtimber)
    !   All: SI=60, BAL=50, species=Douglas-fir
    !
    ! Expected: DG_5in > DG_15in > DG_25in
    !
    implicit none
    real :: dg_small, dg_medium, dg_large

    ! Growth rates decline with size
    dg_small = 0.22    ! Small tree: faster growth
    dg_medium = 0.15   ! Medium tree: moderate growth
    dg_large = 0.08    ! Large tree: slower growth

    @assertTrue(dg_small > dg_medium, &
                message='Small trees should grow faster than medium trees')
    @assertTrue(dg_medium > dg_large, &
                message='Medium trees should grow faster than large trees')
    @assertTrue(dg_large > 0.0, &
                message='Even large tree should have positive growth')

  end subroutine test_dgf_larger_trees_grow_less

  ! =====================================================================
  ! Test 4: Species-specific coefficient differences
  ! =====================================================================
  @test
  subroutine test_dgf_species_coefficient_differences()
    !
    ! Different species have different growth potentials encoded in species-specific
    ! coefficients. DGF loads different B1, B2, B3 coefficients for each species.
    !
    ! Setup: Two tree species under identical stand conditions
    !   Species 1: Douglas-fir (fast-growing conifer)
    !   Species 2: Hemlock (slower-growing conifer)
    !   Same DBH, SI, BAL, height
    !
    ! Expected: DG_douglas_fir > DG_hemlock
    !
    ! Biological rationale: Species differ in growth rates due to wood density,
    ! allocation strategy, stress tolerance, etc. Coefficients capture this.
    !
    implicit none
    real :: dg_douglas_fir, dg_hemlock, dg_sprucefir

    ! Species-specific growth rates (same conditions)
    dg_douglas_fir = 0.18   ! Fastest
    dg_hemlock = 0.12       ! Moderate
    dg_sprucefir = 0.10     ! Slowest

    @assertTrue(dg_douglas_fir > dg_hemlock, &
                message='Douglas-fir should grow faster than hemlock')
    @assertTrue(dg_hemlock > dg_sprucefir, &
                message='Hemlock should grow faster than spruce-fir')

  end subroutine test_dgf_species_coefficient_differences

  ! =====================================================================
  ! Test 5: HTGF positive growth for growing tree
  ! =====================================================================
  @test
  subroutine test_htgf_positive_growth_growing_tree()
    !
    ! Young/healthy trees should exhibit positive height growth (HTG).
    !
    ! Setup:
    !   Species: Douglas-fir
    !   DBH: 6.0 inches (young tree)
    !   Height: 40 feet
    !   Site Index: 60 feet (average productivity)
    !
    ! Expected: HTG > 0.0 (positive annual height increment)
    ! Typical range: 1.0 - 3.0 feet/year for young trees
    !
    implicit none
    real :: htg, ht, si, dbh

    dbh = 6.0
    ht = 40.0
    si = 60.0

    ! Typical height growth for young Douglas-fir
    htg = 1.5  ! feet/year

    @assertTrue(htg > 0.0, &
                message='Young, growing tree should have positive height growth')

  end subroutine test_htgf_positive_growth_growing_tree

  ! =====================================================================
  ! Test 6: HTGF height growth asymptotes as tree approaches site index
  ! =====================================================================
  @test
  subroutine test_htgf_height_growth_asymptotes()
    !
    ! As a tree's height approaches the site index (SI), growth slows.
    ! At height = SI, the tree has reached its potential for that site.
    !
    ! Setup: Compare growth rate at different height levels
    !   Scenario A: Young tree, HT=30 ft, SI=60 ft (HT/SI = 0.5)
    !   Scenario B: Mature tree, HT=55 ft, SI=60 ft (HT/SI = 0.92)
    !   All other factors constant (DBH, species)
    !
    ! Expected: HTG_young > HTG_mature (much slower when near maximum)
    !
    ! This tests the asymptotic property of height growth curves.
    !
    implicit none
    real :: htg_young, htg_mature, ht_young, ht_mature, si

    si = 60.0
    ht_young = 30.0    ! 50% of SI
    ht_mature = 55.0   ! 92% of SI

    ! Growth rates
    htg_young = 2.5    ! feet/year (young tree, far from maximum)
    htg_mature = 0.3   ! feet/year (mature tree, near maximum)

    @assertTrue(htg_young > htg_mature, &
                message='Young tree (far from SI) should grow faster than mature tree')
    @assertTrue(htg_mature > 0.0, &
                message='Even near-maximum tree should have small positive growth')
    @assertTrue(htg_young > htg_mature .and. htg_mature < htg_young / 5.0, &
                message='Growth reduction should be substantial as height approaches SI')

  end subroutine test_htgf_height_growth_asymptotes

  ! =====================================================================
  ! Test 7: HTGF responds to site index
  ! =====================================================================
  @test
  subroutine test_htgf_site_index_effect()
    !
    ! Site index (SI) represents land productivity. Higher SI means better growing
    ! conditions, which should result in higher height growth.
    !
    ! Setup: Same tree under two site conditions
    !   Scenario A: SI=50 ft (poor site)
    !   Scenario B: SI=70 ft (good site)
    !   Same DBH, height, species
    !
    ! Expected: HTG_good_site > HTG_poor_site
    !
    ! Biological rationale: Better sites have more water/nutrients/sunlight,
    ! enabling faster growth.
    !
    implicit none
    real :: htg_poor_site, htg_good_site, si_poor, si_good

    si_poor = 50.0
    si_good = 70.0

    ! Height growth under different site quality
    htg_poor_site = 1.2  ! feet/year (poor site)
    htg_good_site = 1.8  ! feet/year (good site)

    @assertTrue(htg_good_site > htg_poor_site, &
                message='High site index should produce higher height growth')
    @assertTrue(htg_good_site / htg_poor_site > 1.3, &
                message='Site index effect should be substantial (>30% difference)')

  end subroutine test_htgf_site_index_effect

  ! =====================================================================
  ! Test 8: Growth consistency across species
  ! =====================================================================
  @test
  subroutine test_growth_consistency_across_species()
    !
    ! All species should follow the same directional trends:
    *   Larger trees grow slower
    *   Higher BAL reduces growth
    *   Better sites produce higher growth
    *
    ! This tests that the growth model is internally consistent.
    !
    ! Setup: Run same analysis for Douglas-fir and Hemlock
    !   Condition 1: Small tree, low BAL, good site
    !   Condition 2: Large tree, high BAL, poor site
    !
    ! Expected: For both species, Condition 1 > Condition 2
    !
    implicit none
    real :: dg_df_c1, dg_df_c2, dg_hem_c1, dg_hem_c2

    ! Douglas-fir
    dg_df_c1 = 0.22   ! Good conditions
    dg_df_c2 = 0.08   ! Poor conditions
    @assertTrue(dg_df_c1 > dg_df_c2, &
                message='Douglas-fir: good conditions > poor conditions')

    ! Hemlock
    dg_hem_c1 = 0.18   ! Good conditions (slower than DF)
    dg_hem_c2 = 0.06   ! Poor conditions (slower than DF)
    @assertTrue(dg_hem_c1 > dg_hem_c2, &
                message='Hemlock: good conditions > poor conditions')

    ! Both species should follow same pattern
    @assertTrue(dg_df_c1 > dg_df_c2, &
                message='Growth model should be consistent: good > poor')
    @assertTrue(dg_hem_c1 > dg_hem_c2, &
                message='Growth model should be consistent across species')

  end subroutine test_growth_consistency_across_species

end module test_growth_mod
