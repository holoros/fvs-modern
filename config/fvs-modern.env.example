# =============================================================================
# fvs-modern Environment Configuration
# =============================================================================
# Copy this file to fvs-modern.env and customize for your system.
# These variables override hardcoded defaults in R scripts and SLURM jobs.
#
# Usage:
#   source config/fvs-modern.env       (from repo root)
#   export $(cat config/fvs-modern.env | grep -v '^#' | xargs)
# =============================================================================

# --- Project paths -----------------------------------------------------------
# Root of the fvs-modern repository (auto-detected in most scripts)
# FVS_PROJECT_ROOT="/path/to/fvs-modern"

# --- HPC configuration (for SLURM job submission) ----------------------------
# FVS_HPC_HOST="your-hpc.institution.edu"
# FVS_HPC_USER="yourusername"
# FVS_HPC_ACCOUNT="your_account_code"
# FVS_HPC_REMOTE_ROOT="/path/on/hpc/to/fvs-modern"

# --- FIA data paths ----------------------------------------------------------
# FVS_FIA_DATA_DIR="/path/to/FIA/data"

# --- Calibration toggles (used by 19_fia_benchmark_engine.R) -----------------
# FVS_CLIMATE_SI=true
# FVS_SDIMAX=true
# FVS_INGROWTH=true
# FVS_DG_BACKTRANSFORM=median
# FVS_CI_BRACKETS=true
# FVS_BOOTSTRAP=true
# FVS_DG_VARIANT_MULT=false
# FVS_OUTPUT_TAG=""

# --- Stan/brms configuration -------------------------------------------------
# CMDSTAN_PATH="/path/to/cmdstan"
