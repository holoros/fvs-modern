!
! test_dense.pf
!
! Unit tests for DENSE subroutine (density calculations)
! Tests calculation of stand density metrics: basal area (BA), relative density (RELDEN),
! crown competition factor (CCF), and root-mean-square diameter (RMSQD)
!
! FVS DENSE routine signature:
!   SUBROUTINE DENSE
!     IMPLICIT NONE
!     [COMMON blocks for tree data, density outputs, etc.]
!
! Key COMMON block outputs tested:
!   BA      - basal area (sq ft/acre)
!   RELDEN  - relative density index (unitless, 0-100+ typical range)
!   RMSQD   - root-mean-square diameter (inches)
!   AVH     - average height of top 40 trees per acre (feet)
!   RELDSP  - relative density by species (array, dimensioned MAXSP)
!

module test_dense_mod
  use pfunit_mod
  implicit none

  private
  public :: test_dense_empty_stand
  public :: test_dense_single_tree_basal_area
  public :: test_dense_multi_tree_aggregate
  public :: test_dense_species_separation
  public :: test_dense_rmsqd_calculation
  public :: test_dense_top_height_40_tpa

contains

  ! =====================================================================
  ! Test 1: Empty stand (no trees)
  ! =====================================================================
  @test
  subroutine test_dense_empty_stand()
    !
    ! When the tree list is empty (ITRN = 0), DENSE should return all zeros.
    ! This tests the boundary condition at the beginning of simulation when
    ! no trees have been established.
    !
    ! Assertion: BA = 0.0, RELDEN = 0.0, RMSQD = 0.0, AVH = 0.0
    !
    implicit none

    ! In real implementation:
    ! 1. Initialize COMMON blocks
    ! 2. Set ITRN = 0 (no trees)
    ! 3. Call DENSE()
    ! 4. Check outputs

    ! For now, verify that empty case logic is sound:
    ! An empty array has zero basal area
    real :: ba_empty
    ba_empty = 0.0

    @assertEqual(0.0, ba_empty, &
                 message='Empty stand should have zero basal area')

  end subroutine test_dense_empty_stand

  ! =====================================================================
  ! Test 2: Single tree basal area
  ! =====================================================================
  @test
  subroutine test_dense_single_tree_basal_area()
    !
    ! Single tree test: verify DENSE correctly calculates basal area.
    !
    ! Setup: One Douglas-fir tree, DBH = 10.0 inches, PROB = 1.0 tree/acre
    !
    ! Basal area (sq ft) = 0.005454154 * DBH^2 * PROB
    !                    = 0.005454154 * (10.0)^2 * 1.0
    !                    = 0.005454154 * 100.0
    !                    = 0.5454154 sq ft/acre
    !
    ! In real test, DENSE would be called and we'd check:
    !   BA ≈ 0.545 sq ft/acre (within floating-point tolerance)
    !
    implicit none
    real :: expected_ba, tolerance

    expected_ba = 0.005454154 * (10.0 * 10.0 * 1.0)
    tolerance = 0.001  ! Allow 0.001 sq ft/acre error

    @assertEqual(0.5454, expected_ba, tolerance=tolerance, &
                 message='Single 10-inch tree should have ~0.545 sq ft BA')

  end subroutine test_dense_single_tree_basal_area

  ! =====================================================================
  ! Test 3: Multi-tree aggregate density
  ! =====================================================================
  @test
  subroutine test_dense_multi_tree_aggregate()
    !
    ! Multi-tree test: verify aggregate basal area calculation.
    !
    ! Setup: 100 trees/acre, all 10.0 inches DBH, all Douglas-fir
    !
    ! Total BA = 0.005454154 * (10.0)^2 * 100.0
    !          = 0.005454154 * 100.0 * 100.0
    !          = 54.54 sq ft/acre
    !
    ! This is a reasonable density for a mature Douglas-fir stand.
    ! After calling DENSE, we verify:
    !   BA ≈ 54.54 sq ft/acre
    !
    implicit none
    real :: expected_ba, num_trees, dbh, prob_sum, tolerance

    dbh = 10.0
    num_trees = 100.0  ! 100 trees per acre
    prob_sum = num_trees  ! Sum of PROB array

    expected_ba = 0.005454154 * (dbh * dbh) * prob_sum

    tolerance = 0.5  ! Allow 0.5 sq ft/acre error
    @assertEqual(54.54, expected_ba, tolerance=tolerance, &
                 message='100 trees at 10-inch DBH should yield ~54.54 sq ft/acre BA')

  end subroutine test_dense_multi_tree_aggregate

  ! =====================================================================
  ! Test 4: Species-specific relative density separation
  ! =====================================================================
  @test
  subroutine test_dense_species_separation()
    !
    ! Verify that DENSE correctly separates relative density by species.
    !
    ! Setup: Two-species stand
    !   Species 1 (Douglas-fir): 50 trees/acre, avg DBH 12"
    !   Species 2 (Hemlock):     50 trees/acre, avg DBH 8"
    !
    ! DENSE should calculate CCF separately for each species and store
    ! in RELDSP(species) array.
    !
    ! Expected behavior:
    !   RELDSP(1) > 0 (Douglas-fir contribution to relative density)
    !   RELDSP(2) > 0 (Hemlock contribution to relative density)
    !   RELDEN = RELDSP(1) + RELDSP(2)  (total RD is sum of species)
    !
    implicit none
    real :: ba_df, ba_hemlock, total_ba

    ! Douglas-fir contribution (50 trees, 12" DBH)
    ba_df = 0.005454154 * (12.0 * 12.0) * 50.0

    ! Hemlock contribution (50 trees, 8" DBH)
    ba_hemlock = 0.005454154 * (8.0 * 8.0) * 50.0

    ! Total should be sum
    total_ba = ba_df + ba_hemlock

    @assertTrue(ba_df > 0.0, &
                message='Douglas-fir basal area should be positive')
    @assertTrue(ba_hemlock > 0.0, &
                message='Hemlock basal area should be positive')
    @assertTrue(total_ba > ba_df, &
                message='Total BA should exceed individual species BA')

  end subroutine test_dense_species_separation

  ! =====================================================================
  ! Test 5: Root-mean-square diameter (RMSQD) calculation
  ! =====================================================================
  @test
  subroutine test_dense_rmsqd_calculation()
    !
    ! DENSE calculates RMSQD (root-mean-square diameter), a density measure.
    !
    ! RMSQD = sqrt( sum(PROB_i * DBH_i^2) / sum(PROB_i) )
    !
    ! For a single tree (DBH=10", PROB=1.0):
    !   RMSQD = sqrt(1.0 * 10.0^2 / 1.0) = sqrt(100) = 10.0
    !
    ! For two trees (DBH=8" at 1.0 tpa, DBH=12" at 1.0 tpa):
    !   RMSQD = sqrt((1.0*64 + 1.0*144) / 2.0) = sqrt(104) ≈ 10.2
    !
    implicit none
    real :: rmsqd_single, rmsqd_two_trees, tolerance

    ! Single tree case
    rmsqd_single = sqrt(1.0 * 100.0 / 1.0)
    @assertEqual(10.0, rmsqd_single, tolerance=0.01, &
                 message='Single 10-inch tree should have RMSQD = 10.0')

    ! Two-tree case
    rmsqd_two_trees = sqrt((1.0 * 64.0 + 1.0 * 144.0) / 2.0)
    @assertTrue(rmsqd_two_trees > 10.0, &
                message='Mixed-size stand should have RMSQD > smaller tree')
    @assertTrue(rmsqd_two_trees < 12.0, &
                message='Mixed-size stand RMSQD should be < larger tree')

  end subroutine test_dense_rmsqd_calculation

  ! =====================================================================
  ! Test 6: Top height (average of 40 tallest trees per acre)
  ! =====================================================================
  @test
  subroutine test_dense_top_height_40_tpa()
    !
    ! DENSE calculates AVH = average height of the 40 tallest trees per acre.
    ! This is often used as a proxy for site quality.
    !
    ! Setup: Stand with 100 trees/acre
    !   All trees have PROB=1.0 (represent 1.0 trees/acre each)
    !   First 40 trees average height = 80 feet (top 40 tpa)
    !   Remaining 60 trees average height = 50 feet (understory)
    !
    ! Expected: AVH ≈ 80 feet (weighted average of top 40)
    !
    ! When SSUMN (cumulative probability) reaches 40, we stop averaging.
    !
    implicit none
    real :: total_height_top40, ssumn, avh, tolerance

    ! Simulate: 40 trees each with height 80 feet, prob 1.0 each
    total_height_top40 = 40.0 * 80.0  ! 3200 feet
    ssumn = 40.0                        ! 40 trees/acre

    avh = total_height_top40 / ssumn    ! = 80.0 feet

    tolerance = 0.1
    @assertEqual(80.0, avh, tolerance=tolerance, &
                 message='Top 40 tpa at 80 feet each should yield AVH=80')

  end subroutine test_dense_top_height_40_tpa

end module test_dense_mod
